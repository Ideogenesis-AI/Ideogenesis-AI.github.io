---
const nodes = [
  {
    id: 'yuzuha',
    name: 'Yuzuha',
    subtitle: 'CG Engine',
    description: 'SU(2) Clebsch–Gordan recoupling engine. Computes angular momentum coupling coefficients for symmetry-aware tensor contractions.',
    pypi: 'yuzuha',
    href: 'https://github.com/Ideogenesis-AI/Yuzuha',
  },
  {
    id: 'nicole',
    name: 'Nicole',
    subtitle: 'Tensor Library',
    description: 'Symmetry-aware tensor library for many-body systems. Provides SU(2)-invariant tensor objects that preserve quantum numbers exactly.',
    pypi: 'nicole',
    href: 'https://github.com/Ideogenesis-AI/Nicole',
  },
  {
    id: 'alice',
    name: 'Alice',
    subtitle: 'TN Algorithms',
    description: '1D tensor network algorithms built on Nicole. Implements DMRG, MPS, and MPO-based methods for ground state and dynamics.',
    pypi: 'alice-net',
    href: 'https://github.com/Ideogenesis-AI/Alice',
  },
  {
    id: 'ai',
    name: 'Ideogenesis',
    subtitle: 'AI Framework',
    description: 'Transformer-based architectures trained on simulation data to discover emergent correlations and physical patterns.',
    pypi: null,
    tag: 'Private · Python',
    href: 'https://github.com/Ideogenesis-AI',
    isDestination: true,
  },
];
---

<section class="pipeline" id="pipeline">
  <div class="container">
    <div class="pipeline__header reveal">
      <div class="section-label">Technology Stack</div>
      <h2 class="section-heading">From Simulation to Discovery</h2>
      <p class="pipeline__intro">
        The simulation stack flows upward — each layer feeds the next, culminating in
        data that trains the Ideogenesis AI framework.
      </p>
    </div>

    <!-- Desktop: horizontal flow -->
    <div class="pipeline__flow reveal-stagger" id="pipeline-flow" aria-label="Technology pipeline">
          {nodes.map((node, i) => (
            <div class="pipeline__step">
              <a
                href={node.href}
                class:list={['pipeline__node', { 'pipeline__node--destination': node.isDestination }]}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${node.name}: ${node.description}`}
              >
                <div class="node__header">
                  <span class="node__name">{node.name}</span>
                  <span class="node__subtitle">{node.subtitle}</span>
                </div>
                <p class="node__desc">{node.description}</p>
                <span class="node__tag" data-pypi={node.pypi ?? undefined}>
                  {node.tag ?? 'Python'}
                </span>
              </a>

          {i < nodes.length - 1 && (
            <div class="pipeline__connector" aria-hidden="true">
              <svg class="connector__svg" viewBox="0 0 60 24" fill="none">
                <line class="connector__track" x1="2" y1="12" x2="50" y2="12"/>
                <polyline class="connector__arrow" points="44,7 53,12 44,17"/>
              </svg>
              <!-- Gradient sweep -->
              <div class="connector__sweep"></div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Mobile: vertical flow -->
    <ol class="pipeline__vertical reveal-stagger">
      {nodes.map((node, i) => (
        <li class="pipeline__vitem">
          <div class="vitem__marker" aria-hidden="true">
            <span class="vitem__dot"></span>
            {i < nodes.length - 1 && <span class="vitem__line"></span>}
          </div>
          <a
            href={node.href}
            class:list={['vitem__card', { 'vitem__card--destination': node.isDestination }]}
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="vitem__header">
              <span class="vitem__name">{node.name}</span>
              <span class="vitem__subtitle">{node.subtitle}</span>
            </div>
            <p class="vitem__desc">{node.description}</p>
            <span class="node__tag" data-pypi={node.pypi ?? undefined}>
              {node.tag ?? 'Python'}
            </span>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .pipeline {
    background: var(--bg-alt);
    padding-block: var(--space-10);
  }

  .pipeline__header {
    max-width: 560px;
    margin-bottom: var(--space-9);
  }

  .pipeline__intro {
    font-size: clamp(0.9375rem, 1.5vw, 1.05rem);
    color: var(--text-muted);
    line-height: 1.7;
    margin-top: var(--space-4);
  }

  /* ── Desktop: horizontal flow ── */
  .pipeline__flow {
    display: none;
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .pipeline__flow {
      display: flex;
    }
    .pipeline__vertical {
      display: none;
    }
  }

  .pipeline__step {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
  }

  .pipeline__node {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.25s var(--ease-out), background 0.25s;
    height: 100%;
    align-self: stretch;
  }

  .pipeline__node:hover {
    border-color: rgba(61, 142, 248, 0.5);
    background: var(--bg-surface-hover);
  }

  .pipeline__node--destination {
    border-color: rgba(139, 92, 246, 0.25);
  }

  .pipeline__node--destination:hover {
    border-color: rgba(139, 92, 246, 0.6);
  }

  .node__header {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .node__name {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-mono);
    letter-spacing: -0.01em;
  }

  .pipeline__node--destination .node__name {
    color: #c4b5fd;
  }

  .node__subtitle {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-cyan);
    font-family: var(--font-mono);
  }

  .pipeline__node--destination .node__subtitle {
    color: #a78bfa;
  }

  .node__desc {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .node__tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }

  /* Connector between nodes */
  .pipeline__connector {
    flex-shrink: 0;
    width: 60px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .connector__svg {
    width: 100%;
    height: 24px;
  }

  .connector__track {
    stroke: var(--text-faint);
    stroke-width: 1;
  }

  .connector__arrow {
    stroke: var(--text-faint);
    stroke-width: 1.5;
    fill: none;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  /* Gradient sweep (replaces traveling dot) */
  .connector__sweep {
    position: absolute;
    width: 26px;
    height: 2px;
    top: 50%;
    left: -26px;
    transform: translateY(-50%);
    background: linear-gradient(to right, transparent, var(--accent-cyan) 50%, transparent);
    border-radius: 1px;
    opacity: 0;
  }

  /* Animated state — class added by IntersectionObserver */
  .pipeline__flow.pipeline-visible .connector__sweep {
    animation: sweep-x 2.4s linear infinite;
  }

  @keyframes sweep-x {
    0%   { transform: translateX(-26px) translateY(-50%); opacity: 0; }
    25%  { transform: translateX(-5px)  translateY(-50%); opacity: 1; }
    75%  { transform: translateX(39px)  translateY(-50%); opacity: 1; }
    100% { transform: translateX(60px)  translateY(-50%); opacity: 0; }
  }

  /* ── Mobile: vertical flow ── */
  .pipeline__vertical {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media (min-width: 768px) {
    .pipeline__vertical {
      display: none !important;
    }
  }

  .pipeline__vitem {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .vitem__marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: var(--space-5);
    flex-shrink: 0;
  }

  .vitem__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent-cyan);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .vitem__dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1.5px solid var(--accent-cyan);
    opacity: 0;
    transform: scale(0.6);
  }

  .pipeline__vertical.pipeline-visible .vitem__dot::after {
    animation: dot-pulse 2.4s linear infinite;
  }

  @keyframes dot-pulse {
    0%   { transform: scale(0.6); opacity: 0.7; }
    30%  { transform: scale(1.6); opacity: 0; }
    100% { transform: scale(1.6); opacity: 0; }
  }

  .vitem__line {
    width: 1px;
    flex: 1;
    min-height: var(--space-5);
    background: var(--border-subtle);
    margin-top: var(--space-2);
    position: relative;
    overflow: hidden;
    --vline-h: 60px;
  }

  .vitem__line::after {
    content: '';
    position: absolute;
    left: -0.5px;
    top: 0;
    width: 2px;
    height: 22px;
    background: linear-gradient(to bottom, transparent, var(--accent-cyan), transparent);
    transform: translateY(-22px);
    opacity: 0;
  }

  .pipeline__vertical.pipeline-visible .vitem__line::after {
    animation: vsweep 2.4s linear infinite;
  }

  @keyframes vsweep {
    0%   { transform: translateY(-22px);              opacity: 0; }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { transform: translateY(var(--vline-h));     opacity: 0; }
  }

  .vitem__card {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-4);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .vitem__card:hover {
    border-color: rgba(61, 142, 248, 0.4);
  }

  .vitem__card--destination {
    border-color: rgba(139, 92, 246, 0.2);
  }

  .vitem__card--destination:hover {
    border-color: rgba(139, 92, 246, 0.5);
  }

  .vitem__header {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .vitem__name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .vitem__card--destination .vitem__name {
    color: #c4b5fd;
  }

  .vitem__subtitle {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent-cyan);
  }

  .vitem__card--destination .vitem__subtitle {
    color: #a78bfa;
  }

  .vitem__desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>

<script is:inline>
  (function () {
    // ── PyPI version fetch ────────────────────────────────────
    var tags = document.querySelectorAll('[data-pypi]');
    tags.forEach(function (el) {
      var pkg = el.getAttribute('data-pypi');
      if (!pkg) return;
      fetch('https://pypi.org/pypi/' + pkg + '/json')
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          if (data && data.info && data.info.version) {
            el.textContent = 'v' + data.info.version + ' · Python';
          }
        })
        .catch(function () { /* keep placeholder */ });
    });

    // ── Pipeline animations ───────────────────────────────────
    var flow    = document.getElementById('pipeline-flow');
    var vlist   = document.querySelector('.pipeline__vertical');
    if (!flow && !vlist) return;

    function setLineHeights() {
      var lines = document.querySelectorAll('.vitem__line');
      lines.forEach(function (line) {
        line.style.setProperty('--vline-h', line.offsetHeight + 'px');
      });
    }

    // Horizontal flow visibility
    if (flow) {
      var ioH = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            flow.classList.add('pipeline-visible');
            ioH.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      ioH.observe(flow);
    }

    // Vertical flow visibility + line heights
    if (vlist) {
      setLineHeights();
      window.addEventListener('resize', setLineHeights, { passive: true });

      var ioV = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            setLineHeights();
            vlist.classList.add('pipeline-visible');
            ioV.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      ioV.observe(vlist);
    }
  })();
</script>
