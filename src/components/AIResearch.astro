---
const features = [
  {
    name: 'Transformer',
    role: 'Core Architecture',
    description:
      'State-of-the-art transformer architecture optimized for lattice system analysis, featuring novel attention mechanisms with locality biases and modular Processor/Propagator/Attention building blocks.',
  },
  {
    name: 'Analysis',
    role: 'Diagnostic Tools',
    description:
      'Advanced model diagnostics implementing attention propagation analysis, carrier transitions, Markov spectrum computation, and Omnimetry — a statistical framework for measuring physical observables.',
  },
  {
    name: 'Visualize',
    role: 'Visualization Suite',
    description:
      'Comprehensive visualization that transforms complex model outputs into intuitive representations, with TensorBoard integration and specialized attention visualization tools.',
  },
];
---

<section class="research" id="research">
  <div class="container">
    <div class="research__header reveal">
      <div class="section-label section-label--purple">AI Research</div>
      <h2 class="section-heading">
        The Ideogenesis Framework
      </h2>
      <p class="research__intro">
        Built on top of the technology stack, the Ideogenesis Framework provides a
        comprehensive suite of transformer-based architectures and analysis tools for
        discovering emergent physics from data.
      </p>
    </div>

    <div class="research__grid reveal-stagger">
      {features.map((f) => (
        <div class="research__card">
          <div class="card__accent" aria-hidden="true"></div>
          <div class="card__body">
            <div class="card__header">
              <span class="card__name">{f.name}</span>
              <span class="card__role">{f.role}</span>
            </div>
            <p class="card__desc">{f.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Strata CLI — full-width highlight card -->
    <div class="strata reveal">
      <div class="strata__icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
        </svg>
      </div>
      <div class="strata__body">
        <div class="strata__header">
          <span class="strata__name">Strata CLI</span>
          <span class="strata__tag">Resource management</span>
        </div>
        <p class="strata__desc">
          A Homebrew-inspired resource management system that streamlines handling of datasets,
          models, and experimental artifacts — with centralized registry management, automatic
          versioning, and dependency resolution.
        </p>
      </div>
      <a
        href="https://github.com/Ideogenesis-AI"
        class="strata__cta"
        target="_blank"
        rel="noopener noreferrer"
      >View org ↗</a>
    </div>

    <!-- HuggingFace resources -->
    <div class="hf-strip reveal">
      <svg class="hf-strip__icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18c-4.411 0-8-3.589-8-8s3.589-8 8-8 8 3.589 8 8-3.589 8-8 8zm-1-11h2v6h-2zm0 8h2v2h-2z"/>
      </svg>
      <p>
        Pre-trained models and curated datasets available on
        <a href="https://huggingface.co/ideogenesis" target="_blank" rel="noopener noreferrer">Hugging Face</a>
        — lattice systems, quantum simulations, and complex dynamical data.
      </p>
    </div>
  </div>
</section>

<style>
  .research {
    background: var(--bg-base);
    padding-block: var(--space-10);
  }

  .research__header {
    max-width: 620px;
    margin-bottom: var(--space-9);
  }

  .research__intro {
    font-size: clamp(0.9375rem, 1.5vw, 1.05rem);
    color: var(--text-muted);
    line-height: 1.7;
    margin-top: var(--space-4);
  }

  /* Purple label variant */
  .section-label--purple {
    color: var(--accent-purple);
  }

  /* Feature grid */
  .research__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .research__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .research__card {
    position: relative;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.25s var(--ease-out), background 0.25s;
  }

  .research__card:hover {
    border-color: rgba(139, 92, 246, 0.4);
    background: var(--bg-surface-hover);
  }

  .card__accent {
    height: 2px;
    background: linear-gradient(90deg, var(--accent-purple), transparent);
  }

  .card__body {
    padding: var(--space-5) var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .card__header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .card__name {
    font-family: var(--font-mono);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #c4b5fd;
    letter-spacing: -0.01em;
  }

  .card__role {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .card__desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* Strata CLI full-width card */
  .strata {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-6);
    background: var(--bg-surface);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: 12px;
    margin-bottom: var(--space-5);
    transition: border-color 0.2s;
    flex-wrap: wrap;
  }

  .strata:hover {
    border-color: rgba(139, 92, 246, 0.4);
  }

  .strata__icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(139, 92, 246, 0.1);
    border-radius: 10px;
    color: var(--accent-purple);
    flex-shrink: 0;
  }

  .strata__body {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .strata__header {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .strata__name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    color: #c4b5fd;
  }

  .strata__tag {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .strata__desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .strata__cta {
    align-self: center;
    padding: var(--space-2) var(--space-4);
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #c4b5fd;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.2s, background 0.2s;
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .strata__cta:hover {
    border-color: var(--accent-purple);
    background: rgba(139, 92, 246, 0.1);
    color: #c4b5fd;
  }

  /* HuggingFace strip */
  .hf-strip {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
  }

  .hf-strip__icon {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .hf-strip p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .hf-strip a {
    color: var(--accent-blue);
  }

  .hf-strip a:hover {
    color: var(--accent-cyan);
  }
</style>
