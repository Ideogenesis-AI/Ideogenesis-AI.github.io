---
const links = [
  {
    label: 'GitHub Organization',
    href: 'https://github.com/Ideogenesis-AI',
    icon: `<path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>`,
  },
  {
    label: 'Hugging Face',
    href: 'https://huggingface.co/ideogenesis',
    icon: `<circle cx="12" cy="12" r="10"/><path d="M8.5 14.5s1 1.5 3.5 1.5 3.5-1.5 3.5-1.5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round"/><circle cx="9" cy="10" r="1.2" fill="currentColor"/><circle cx="15" cy="10" r="1.2" fill="currentColor"/>`,
    useStroke: true,
  },
  {
    label: 'contact@ideogenesis.ai',
    href: 'mailto:contact@ideogenesis.ai',
    icon: `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>`,
    useStroke: true,
  },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Ideogenesis AI home">
        <svg width="22" height="22" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <polygon points="14,2 24,7.5 24,18.5 14,24 4,18.5 4,7.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <circle cx="14" cy="13" r="2" fill="currentColor"/>
          <line x1="14" y1="2"  x2="14" y2="11" stroke="currentColor" stroke-width="1" opacity="0.5"/>
          <line x1="24" y1="7.5"  x2="16.7" y2="11.5" stroke="currentColor" stroke-width="1" opacity="0.5"/>
          <line x1="24" y1="18.5" x2="16.7" y2="14.5" stroke="currentColor" stroke-width="1" opacity="0.5"/>
          <line x1="14" y1="24"  x2="14" y2="15" stroke="currentColor" stroke-width="1" opacity="0.5"/>
          <line x1="4"  y1="18.5" x2="11.3" y2="14.5" stroke="currentColor" stroke-width="1" opacity="0.5"/>
          <line x1="4"  y1="7.5"  x2="11.3" y2="11.5" stroke="currentColor" stroke-width="1" opacity="0.5"/>
        </svg>
        <span>Ideogenesis AI</span>
      </a>
      <p class="footer__tagline">
        Acquisition of new physical insights via AI algorithms on ensembles of data
        from quantum lattice models.
      </p>
    </div>

    <nav class="footer__links" aria-label="Footer links">
      {links.map((l) => (
        <a
          href={l.href}
          class="footer__link"
          target={l.href.startsWith('mailto') ? undefined : '_blank'}
          rel={l.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          aria-label={l.label}
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill={l.useStroke ? 'none' : 'currentColor'}
            stroke={l.useStroke ? 'currentColor' : 'none'}
            stroke-width={l.useStroke ? '1.8' : undefined}
            aria-hidden="true"
            set:html={l.icon}
          />
          <span>{l.label}</span>
        </a>
      ))}
    </nav>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <p>
        &copy; {new Date().getFullYear()} Ideogenesis AI &mdash;
        Licensed under
        <a href="https://www.gnu.org/licenses/agpl-3.0.html" target="_blank" rel="noopener noreferrer">AGPL-3.0</a>
        /
        <a href="https://www.gnu.org/licenses/gpl-3.0.html" target="_blank" rel="noopener noreferrer">GPL-3.0</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-base);
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-9);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .footer__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  /* Brand */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 380px;
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
  }

  .footer__logo svg {
    color: var(--accent-cyan);
    flex-shrink: 0;
  }

  .footer__tagline {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* Links column */
  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex-shrink: 0;
  }

  .footer__link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-muted);
    font-size: 0.875rem;
    text-decoration: none;
    line-height: 2.2;
    transition: color 0.2s;
  }

  .footer__link:hover {
    color: var(--text-primary);
  }

  .footer__link svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .footer__link:hover svg {
    opacity: 1;
  }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid var(--border-subtle);
    padding-block: var(--space-5);
  }

  .footer__bottom p {
    font-size: 0.8125rem;
    color: var(--text-faint);
  }

  .footer__bottom a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .footer__bottom a:hover {
    color: var(--text-primary);
  }
</style>
