---
---

<section class="hero" id="hero">
  <canvas class="hero__canvas" id="lattice-canvas" aria-hidden="true"></canvas>

  <div class="hero__content container">
    <div class="hero__badge reveal">
      <span class="badge__dot"></span>
      <span>Research · AI · Quantum Physics</span>
    </div>

    <h1 class="hero__title reveal">
      <span class="hero__title-word">Ideogenesis</span>
      <span class="hero__title-accent shimmer"> AI</span>
    </h1>

    <p class="hero__tagline reveal">
      Acquiring new physical insights via AI algorithms on ensembles<br class="hero__br" />
      of data from quantum lattice simulations
    </p>

    <div class="hero__ctas reveal">
      <a href="#projects" class="btn btn--primary">Explore Projects</a>
      <a
        href="https://github.com/Ideogenesis-AI"
        class="btn btn--secondary"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        View on GitHub
      </a>
    </div>
  </div>

  <div class="hero__scroll-hint" aria-hidden="true">
    <span class="scroll-hint__line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-base);
    overflow: hidden;
  }

  /* Canvas fills the section */
  .hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.38;
    pointer-events: none;
  }

  /* Ring mask: opaque at center (behind text) and at edges, transparent in the band between */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 78% 72% at 50% 50%,
      var(--bg-base)   0%,
      var(--bg-base)  28%,
      transparent     44%,
      transparent     58%,
      var(--bg-base)  74%
    );
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-top: calc(var(--nav-h) + var(--space-8));
    padding-bottom: var(--space-10);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  /* Badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .badge__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-cyan);
    animation: pulse-glow 2s ease-in-out infinite;
  }

  /* Title */
  .hero__title {
    font-size: clamp(2.75rem, 7vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--text-primary);
  }

  .hero__title-accent {
    display: inline-block;
  }

  /* Shimmer gradient text */
  .shimmer {
    background: linear-gradient(
      90deg,
      var(--accent-cyan) 0%,
      var(--accent-blue) 35%,
      var(--text-primary) 50%,
      var(--accent-blue) 65%,
      var(--accent-cyan) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer 4s linear infinite;
  }

  /* Tagline */
  .hero__tagline {
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    color: var(--text-muted);
    max-width: 600px;
    line-height: 1.65;
    font-weight: 400;
  }

  .hero__br {
    display: none;
  }

  @media (min-width: 640px) {
    .hero__br {
      display: block;
    }
  }

  /* CTAs */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s var(--ease-out);
    min-height: 44px;
  }

  .btn--primary {
    background: var(--accent-cyan);
    color: #060b15;
    border: 1px solid var(--accent-cyan);
  }

  .btn--primary:hover {
    background: #1adbff;
    color: #060b15;
    transform: translateY(-2px);
  }

  .btn--secondary {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-subtle);
  }

  .btn--secondary:hover {
    border-color: var(--accent-blue);
    color: var(--accent-blue);
    transform: translateY(-2px);
    background: rgba(61, 142, 248, 0.06);
  }

  /* Scroll hint */
  .hero__scroll-hint {
    position: absolute;
    bottom: var(--space-7);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  .scroll-hint__line {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, transparent, var(--accent-cyan));
    animation: scroll-fade 2s ease-in-out infinite;
  }

  @keyframes scroll-fade {
    0%   { opacity: 0; transform: scaleY(0); transform-origin: top; }
    50%  { opacity: 1; transform: scaleY(1); transform-origin: top; }
    100% { opacity: 0; transform: scaleY(1); transform-origin: bottom; }
  }

  /* Stagger the hero content reveals */
  .hero__content .reveal:nth-child(1) { animation-delay: 0.1s; }
  .hero__content .reveal:nth-child(2) { animation-delay: 0.2s; }
  .hero__content .reveal:nth-child(3) { animation-delay: 0.3s; }
  .hero__content .reveal:nth-child(4) { animation-delay: 0.4s; }
</style>

<script is:inline>
  (function () {
    var canvas = document.getElementById('lattice-canvas');
    if (!canvas) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      canvas.style.display = 'none';
      return;
    }

    var ctx = canvas.getContext('2d');
    var dpr = window.devicePixelRatio || 1;
    var raf = null;

    var COLS = 18;
    var ROWS = 12;
    var MAX_PARTICLES = 28;
    var MAX_GEN = 3;
    // Split probability per generation
    var SPLIT_P = [0.72, 0.50, 0.28];

    var nodes = [];
    var nodeGlow = [];
    var particles = [];
    var lastT = 0;
    var nextSpawn = 900;

    // ── Lattice ─────────────────────────────────────────────
    function buildLattice(w, h) {
      nodes = []; nodeGlow = []; particles = [];
      var padX = w * 0.05, padY = h * 0.10;
      var sx = (w - padX * 2) / (COLS - 1);
      var sy = (h - padY * 2) / (ROWS - 1);
      for (var r = 0; r < ROWS; r++) {
        for (var c = 0; c < COLS; c++) {
          nodes.push({
            x: padX + c * sx, y: padY + r * sy,
            phase: Math.random() * Math.PI * 2,
            speed: 0.008 + Math.random() * 0.012,
            amp:   0.3   + Math.random() * 0.5,
            col: c, row: r,
          });
          nodeGlow.push(0);
        }
      }
    }

    function neighbors(idx, exclude) {
      var nd = nodes[idx], nb = [];
      if (nd.col > 0)        nb.push(idx - 1);
      if (nd.col < COLS - 1) nb.push(idx + 1);
      if (nd.row > 0)        nb.push(idx - COLS);
      if (nd.row < ROWS - 1) nb.push(idx + COLS);
      return exclude != null ? nb.filter(function(n){ return n !== exclude; }) : nb;
    }

    function spawn(from, to, gen) {
      if (particles.length >= MAX_PARTICLES) return;
      particles.push({ from: from, to: to, progress: 0,
        speed: 0.00055 + Math.random() * 0.00035, gen: gen });
    }

    // ── Particle update ──────────────────────────────────────
    function update(t, dt) {
      // Auto-emit
      if (t >= nextSpawn && particles.length < MAX_PARTICLES - 2) {
        var idx = COLS + 1 + Math.floor(Math.random() * ((ROWS - 2) * COLS - 2));
        var nb = neighbors(idx, null);
        if (nb.length) spawn(idx, nb[Math.floor(Math.random() * nb.length)], 0);
        nextSpawn = t + 1400 + Math.random() * 1800;
      }

      for (var i = particles.length - 1; i >= 0; i--) {
        var p = particles[i];
        p.progress += p.speed * dt;

        if (p.progress >= 1) {
          var arr = p.to;
          nodeGlow[arr] = Math.min(1, nodeGlow[arr] + 0.55);

          if (p.gen < MAX_GEN) {
            var nb2 = neighbors(arr, p.from);
            if (nb2.length && Math.random() < SPLIT_P[p.gen]) {
              var nSplit = (p.gen === 0 && Math.random() < 0.45) ? 2 : 1;
              nSplit = Math.min(nSplit, nb2.length, MAX_PARTICLES - particles.length);
              // Fisher-Yates partial shuffle to pick random targets
              for (var s = 0; s < nSplit; s++) {
                var ri = s + Math.floor(Math.random() * (nb2.length - s));
                var tmp = nb2[s]; nb2[s] = nb2[ri]; nb2[ri] = tmp;
                spawn(arr, nb2[s], p.gen + 1);
              }
            }
          }
          particles.splice(i, 1);
        }
      }

      // Decay glows
      var decay = 0.0022 * dt;
      for (var g = 0; g < nodeGlow.length; g++) {
        if (nodeGlow[g] > 0) nodeGlow[g] = Math.max(0, nodeGlow[g] - decay);
      }
    }

    // ── Draw ─────────────────────────────────────────────────
    function draw(t) {
      var dt = lastT ? Math.min(t - lastT, 50) : 16;
      lastT = t;

      var w = canvas.width / dpr, h = canvas.height / dpr;
      ctx.clearRect(0, 0, w, h);

      update(t, dt);

      var time = t * 0.001;

      // Bonds
      ctx.lineWidth = 0.6;
      for (var i = 0; i < nodes.length; i++) {
        var n = nodes[i];
        var op = (0.5 + 0.5 * Math.sin(time * n.speed * 40 + n.phase)) * 0.18;
        ctx.strokeStyle = 'rgba(0,212,255,' + op + ')';
        if (n.col < COLS - 1) {
          var r2 = nodes[i + 1];
          ctx.beginPath(); ctx.moveTo(n.x, n.y); ctx.lineTo(r2.x, r2.y); ctx.stroke();
        }
        if (i + COLS < nodes.length) {
          var b2 = nodes[i + COLS];
          ctx.beginPath(); ctx.moveTo(n.x, n.y); ctx.lineTo(b2.x, b2.y); ctx.stroke();
        }
      }

      // Node glows (radial, only when visible)
      for (var gi = 0; gi < nodes.length; gi++) {
        var gv = nodeGlow[gi];
        if (gv < 0.03) continue;
        var nd = nodes[gi];
        var grd = ctx.createRadialGradient(nd.x, nd.y, 0, nd.x, nd.y, 13);
        grd.addColorStop(0, 'rgba(0,212,255,' + (gv * 0.16) + ')');
        grd.addColorStop(1, 'rgba(0,212,255,0)');
        ctx.fillStyle = grd;
        ctx.beginPath(); ctx.arc(nd.x, nd.y, 13, 0, Math.PI * 2); ctx.fill();
      }

      // Nodes
      for (var j = 0; j < nodes.length; j++) {
        var nd2 = nodes[j];
        var pulse = 0.4 + nd2.amp * (Math.sin(time * nd2.speed * 40 + nd2.phase) * 0.5 + 0.5);
        var radius = 1.5 + pulse * 1.2;
        var alpha  = Math.min(1, 0.25 + pulse * 0.55 + nodeGlow[j] * 0.4);
        ctx.beginPath(); ctx.arc(nd2.x, nd2.y, radius, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(0,212,255,' + alpha + ')'; ctx.fill();
      }

      // Particles
      for (var pi = 0; pi < particles.length; pi++) {
        var pt = particles[pi];
        var fn = nodes[pt.from], tn = nodes[pt.to];
        var px = fn.x + (tn.x - fn.x) * pt.progress;
        var py = fn.y + (tn.y - fn.y) * pt.progress;
        // Smooth fade-in and fade-out near endpoints
        var fade = Math.min(pt.progress * 5, (1 - pt.progress) * 5, 1);
        ctx.beginPath(); ctx.arc(px, py, 2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(0,212,255,' + (0.72 * fade) + ')'; ctx.fill();
      }

      raf = requestAnimationFrame(draw);
    }

    // ── Init ─────────────────────────────────────────────────
    function resize() {
      var w = canvas.offsetWidth, h = canvas.offsetHeight;
      canvas.width  = w * dpr; canvas.height = h * dpr;
      ctx.scale(dpr, dpr);
      buildLattice(w, h);
    }

    resize();
    raf = requestAnimationFrame(draw);

    var rTimer;
    window.addEventListener('resize', function () {
      clearTimeout(rTimer);
      rTimer = setTimeout(resize, 150);
    }, { passive: true });

    document.addEventListener('visibilitychange', function () {
      if (document.hidden) { cancelAnimationFrame(raf); raf = null; lastT = 0; }
      else if (!raf) { raf = requestAnimationFrame(draw); }
    });
  })();
</script>
