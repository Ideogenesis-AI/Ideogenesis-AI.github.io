---
const stats = [
  {
    num: '01',
    heading: 'Symmetry-Exact Tensors',
    note: 'Abelian and non-Abelian quantum numbers conserved exactly across all tensor operations',
  },
  {
    num: '02',
    heading: 'Tensor Network Methods',
    note: 'Ground state, finite temperature, and real-time dynamics for quantum many-body systems',
  },
  {
    num: '03',
    heading: 'Quantum Lattice Models',
    note: 'Spin chains, Hubbard models, and frustrated geometries spanning 1D to quasi-2D',
  },
  {
    num: '04',
    heading: 'AI-Driven Discovery',
    note: 'Emergent physical correlations uncovered from quantum simulation ensembles',
  },
];
---

<section class="stats" id="stats" aria-label="Key highlights">
  <div class="container">
    <ul class="stats__grid reveal-stagger">
      {stats.map((s) => (
        <li class="stats__item">
          <span class="stats__num" aria-hidden="true">{s.num}</span>
          <span class="stats__heading">{s.heading}</span>
          <span class="stats__note">{s.note}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .stats {
    background: var(--bg-alt);
    padding-block: var(--space-8);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }



  .stats__grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-7) var(--space-6);
  }

  @media (min-width: 768px) {
    .stats__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-5) var(--space-6);
    }
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-subtle);
    transition: border-top-color 0.2s ease;
  }

  .stats__item:hover {
    border-top-color: var(--accent-cyan);
  }

  .stats__num {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--accent-cyan);
    letter-spacing: 0.1em;
    line-height: 1;
    margin-bottom: var(--space-1);
  }

  .stats__heading {
    font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .stats__note {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.55;
  }
</style>
